{
  "name": "knapsack",
  "sets": {
    "I": { "description": "items" }
  },
  "parameters": {
    "v": { "indices": ["I"], "description": "item values" },
    "w": { "indices": ["I"], "description": "item weights" },
    "W": { "indices": [], "description": "knapsack capacity" }
  },
  "variables": {
    "x": {
      "indices": ["I"],
      "type": "binary",
      "lower_bound": 0,
      "upper_bound": 1,
      "description": "1 if item is selected"
    }
  },
  "objective": {
    "sense": "maximize",
    "expression": "sum(v[i] * x[i] for i in I)"
  },
  "constraints": {
    "capacity": {
      "for_all": [],
      "expression": "sum(w[i] * x[i] for i in I) <= W"
    }
  },
  "warnings": []
}
