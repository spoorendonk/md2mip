{
  "name": "tsp_mtz",
  "sets": {
    "N": { "description": "cities" }
  },
  "parameters": {
    "dist": { "indices": ["N", "N"], "description": "travel distance" },
    "n_cities": { "indices": [], "description": "number of cities" },
    "mtz_ub": { "indices": ["N", "N"], "description": "deactivation bound for MTZ (0=active, large=inactive)" }
  },
  "variables": {
    "x": {
      "indices": ["N", "N"],
      "type": "binary",
      "lower_bound": 0,
      "upper_bound": 1,
      "description": "1 if tour goes from i to j"
    },
    "u": {
      "indices": ["N"],
      "type": "continuous",
      "lower_bound": 0,
      "upper_bound": 4,
      "description": "position of city in tour"
    }
  },
  "objective": {
    "sense": "minimize",
    "expression": "sum(dist[i,j] * x[i,j] for i in N for j in N)"
  },
  "constraints": {
    "leave": {
      "for_all": ["i in N"],
      "expression": "sum(x[i,j] for j in N) == 1"
    },
    "enter": {
      "for_all": ["i in N"],
      "expression": "sum(x[j,i] for j in N) == 1"
    },
    "no_self": {
      "for_all": ["i in N"],
      "expression": "x[i,i] <= 0"
    },
    "mtz": {
      "for_all": ["i in N", "j in N"],
      "expression": "u[i] - u[j] + n_cities * x[i,j] <= n_cities - 1 + mtz_ub[i,j]"
    }
  },
  "warnings": []
}
